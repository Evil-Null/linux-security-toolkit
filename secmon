#!/usr/bin/env python3
"""Security Services Monitor — Live TUI"""

import subprocess, time, re
from datetime import datetime
from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.columns import Columns
from rich.text import Text
from rich.live import Live
from rich import box

SERVICES = [
    ("clamav-daemon",    "ClamAV",        "🛡️"),
    ("clamav-freshclam", "ClamAV Update", "🔄"),
    ("fail2ban",         "Fail2Ban",      "🚫"),
    ("auditd",           "AuditD",        "👁️"),
    ("dnscrypt-proxy",   "DNSCrypt",      "🔒"),
    ("docker",           "Docker",        "🐳"),
    ("dnsmasq",          "DNSMasq",       "🌐"),
]

TIMERS = [
    ("dailyaidecheck.timer", "AIDE (File Integrity)"),
    ("lynis.timer",          "Lynis (Audit)"),
    ("rkhunter.timer",       "RKHunter (Rootkit)"),
    ("secaudit.timer",       "SecAudit"),
    ("logwatch.timer",       "Logwatch"),
    ("sysnotify.timer",      "SysNotify"),
    ("sysclean.timer",       "SysClean"),
]

LOG_UNITS = [
    "clamav-daemon", "clamav-freshclam", "fail2ban",
    "auditd", "dnscrypt-proxy", "sysnotify", "secaudit",
    "rkhunter", "lynis",
]

WARN_RE = re.compile(
    r"(WARN|ERROR|FAIL|Blocked|banned|infected|found|WARNING|ALERT)",
    re.IGNORECASE,
)


def run(cmd):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=4)
        return r.stdout.strip()
    except Exception:
        return ""


def get_service_info(unit):
    out = run(["systemctl", "show", unit,
               "--property=ActiveState,SubState,MemoryCurrent"])
    props = dict(l.split("=", 1) for l in out.splitlines() if "=" in l)

    active = props.get("ActiveState", "unknown")
    sub    = props.get("SubState", "")
    mem_b  = props.get("MemoryCurrent", "0")

    if active == "active" and sub == "running":
        status = Text("● running", style="bold green")
    elif active == "active":
        status = Text(f"● {sub}", style="bold cyan")
    elif active == "inactive":
        status = Text("○ inactive", style="dim")
    elif active == "failed":
        status = Text("✗ failed", style="bold red")
    else:
        status = Text(f"? {active}", style="yellow")

    try:
        mb = int(mem_b) / 1024 / 1024
        mem = f"{mb:.1f} MB" if mb > 0.1 else "—"
    except Exception:
        mem = "—"

    return status, mem


_TIMER_CACHE = {}

def _load_timers():
    """Parse `systemctl list-timers --all` once per refresh."""
    out = run(["systemctl", "list-timers", "--all", "--no-pager"])
    data = {}
    for line in out.splitlines()[1:]:
        parts = line.split()
        if not parts:
            continue
        # Find the UNIT column — it ends with .timer
        unit = next((p for p in parts if p.endswith(".timer")), None)
        if not unit:
            continue
        # LEFT column (e.g. "6h", "1min 6s", "5 days") — word after the NEXT datetime
        # PASSED column — word after LAST datetime
        # Format: NEXT(2 words + tz) LEFT(1-3 words) LAST(2 words + tz) PASSED(1-3 words) UNIT
        try:
            left_idx  = line.index(" LEFT ")  if " LEFT " in line else -1
            last_idx  = line.index(" LAST ")  if " LAST " in line else -1
            pass_idx  = line.index(" PASSED ") if " PASSED " in line else -1
            unit_idx  = line.index(unit)

            left  = line[left_idx+6:last_idx].strip() if left_idx >= 0 and last_idx >= 0 else "—"
            passed = line[pass_idx+8:unit_idx].strip() if pass_idx >= 0 else "never"

            # Clean up extra spaces
            left   = " ".join(left.split())
            passed = " ".join(passed.split())
            if not passed or passed == "-":
                passed = "never"
        except Exception:
            left, passed = "—", "never"

        data[unit] = (left, passed)
    return data


def get_timer_info(unit):
    global _TIMER_CACHE
    if not _TIMER_CACHE:
        _TIMER_CACHE = _load_timers()

    active_out = run(["systemctl", "show", unit, "--property=ActiveState"])
    active = active_out.replace("ActiveState=", "").strip()
    state = Text("● on", style="green") if active == "active" else Text("○ off", style="dim")

    left, passed = _TIMER_CACHE.get(unit, ("—", "never"))

    # Color next-run by urgency
    if "s" in left and not any(c in left for c in ("min", "h", "d")):
        left_text = Text(left, style="bold cyan")
    elif left == "—":
        left_text = Text("—", style="dim")
    else:
        left_text = Text(left, style="cyan")

    passed_text = Text(passed, style="dim") if passed != "never" else Text("never", style="dim red")

    return state, left_text, passed_text


def get_fail2ban_stats():
    # Try with sudo -n (no password prompt), fallback to direct
    for cmd in [["sudo", "-n", "fail2ban-client", "status"],
                ["fail2ban-client", "status"]]:
        out = run(cmd)
        if out:
            break
    if not out:
        return []

    jails = []
    for line in out.splitlines():
        if "Jail list:" in line:
            jails = [j.strip() for j in line.split(":", 1)[1].split(",") if j.strip()]

    results = []
    for jail in jails:
        for cmd in [["sudo", "-n", "fail2ban-client", "status", jail],
                    ["fail2ban-client", "status", jail]]:
            jout = run(cmd)
            if jout:
                break
        banned = total = "?"
        for jline in jout.splitlines():
            if "Currently banned" in jline:
                banned = jline.split(":")[-1].strip()
            if "Total banned" in jline:
                total = jline.split(":")[-1].strip()
        results.append((jail, banned, total))
    return results


def get_logs():
    cmd = ["journalctl", "--no-pager", "-n", "16",
           "--output=short-iso", "--since", "24 hours ago"]
    for u in LOG_UNITS:
        cmd += ["-u", u]
    out = run(cmd)
    result = []
    for line in out.splitlines()[-16:]:
        if WARN_RE.search(line):
            result.append(Text(line[:130], style="bold yellow"))
        else:
            result.append(Text(line[:130], style="dim white"))
    return result


def render():
    global _TIMER_CACHE
    _TIMER_CACHE = _load_timers()
    now = datetime.now().strftime("%Y-%m-%d  %H:%M:%S")

    # ── Services ──
    svc = Table(box=box.SIMPLE_HEAD, header_style="bold white",
                show_lines=False, expand=True, padding=(0, 1))
    svc.add_column("", width=2)
    svc.add_column("სახელი", style="white")
    svc.add_column("სტატუსი", width=13)
    svc.add_column("RAM", width=9, justify="right")
    for unit, label, icon in SERVICES:
        status, mem = get_service_info(unit)
        svc.add_row(icon, label, status, Text(mem, style="dim"))

    # ── Timers ──
    tmr = Table(box=box.SIMPLE_HEAD, header_style="bold white",
                show_lines=False, expand=True, padding=(0, 1))
    tmr.add_column("ტაიმერი", style="white")
    tmr.add_column("", width=4)
    tmr.add_column("შემდეგი", width=11, justify="right")
    tmr.add_column("ბოლო", width=10, justify="right")
    for unit, label in TIMERS:
        state, nxt, last = get_timer_info(unit)
        tmr.add_row(label, state, nxt, last)

    # ── Fail2Ban ──
    f2b = Table(box=box.SIMPLE_HEAD, header_style="bold white",
                show_lines=False, expand=True, padding=(0, 1))
    f2b.add_column("Jail", style="white")
    f2b.add_column("Banned", justify="center", width=8)
    f2b.add_column("Total", justify="center", width=7)
    stats = get_fail2ban_stats()
    if stats:
        for jail, banned, total in stats:
            col = "bold red" if banned not in ("0", "?") else "bold green"
            f2b.add_row(jail, Text(banned, style=col), Text(total, style="dim"))
    else:
        f2b.add_row("fail2ban", Text("—", style="dim"), Text("—", style="dim"))

    # ── Logs ──
    log_lines = get_logs()
    log_text = Text()
    for ln in log_lines:
        log_text.append_text(ln)
        log_text.append("\n")

    if not log_lines:
        log_text = Text("ლოგები ვერ მოიძებნა", style="dim")

    from rich.console import Group
    return Group(
        Columns([
            Panel(svc, title="[bold cyan]სერვისები[/bold cyan]",
                  subtitle=f"[dim]{now}  •  q=გასვლა[/dim]",
                  border_style="cyan"),
            Panel(tmr, title="[bold magenta]ტაიმერები[/bold magenta]",
                  border_style="magenta"),
            Panel(f2b, title="[bold red]Fail2Ban Jails[/bold red]",
                  border_style="red"),
        ], expand=True),
        Panel(
            log_text,
            title="[bold yellow]ბოლო ლოგები — security services (24h)[/bold yellow]",
            border_style="yellow",
        ),
    )


def main():
    console = Console()
    try:
        with Live(render(), console=console, refresh_per_second=0.2,
                  screen=True, vertical_overflow="visible") as live:
            while True:
                time.sleep(5)
                live.update(render())
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
